@startuml
left to right direction
title Java Game

'================== Interfaces ==================
package "Interfaces" {
  interface IGameObject {
    + name() : String
    + transform() : Transform
    + collider() : Collider
  }
  interface ITransform {
    + move(Point p, int layer)
    + rotate(double r)
    + scale(double s)
    + position() : Point
    + layer() : int
    + angle() : double
    + scale() : double
  }
  interface ICollider {
    + centroid() : Point
  }
  interface IBehaviour {
    + init() : void
    + onEnabled() : void
    + onDisabled() : void
    + onDestroy() : void
    + onUpdate(double dT, InputEvent ie) : void
    + onCollision(ArrayList<IGameObject> gol) : void
  }
  interface IGameEngine {
    + addEnabled(IGameObject go) : void
    + addDisabled(IGameObject go) : void
    + enable(IGameObject go) : void
    + disable(IGameObject go) : void
    + isEnabled(IGameObject go) : void
    + isDisabled(IGameObject go) : void
    + ArrayList<IGameObject> enabled() : void
    + ArrayList<IGameObject> disabled() : void
    + add(GameObject go) : void
    + destroy(IGameObject go) : void 
    + destroyAll() : void
    + run() : void
    + checkCollisions() : void
  }
}

'================== Game Engine ==================
package "Engine" {
  abstract class Figura {
    - tipoFig : int
    --
    + centroid() : Point
    + scale(double r) : Figura
    + rotate(double r) : Figura
    + translation(double dx, double dy) : Figura
    + translation(Point p) : Figura
    + toString() : String
    + collision(Figura that) : boolean
  }
  
  class Point {
    - x : double
    - y : double
    --
    + x() : double
    + y() : double
    + X() : int
    + Y() : int
    + equals(Point that) : boolean
    + distancia(Point that) : double
    + translacao(double dx, double dy) : Point
    + sum(Point that) : Point
    + colinear(Point a, Point b, Point c) : boolean
    + flipSign() : Point
    + scale(double s) : Point
    + rotate(double deg) : Point
    + vetor(Point that) : Point
    + vetorPI(Point v1, Point v2) : double
    + vetorPE(Point v1, Point v2) : double
    + toString() : String
  }
  
  class Transform {
    - layer : int
    - angle : double
    - angleOld : double
    - scale : double
    - scaleOld : double
    --
    + move(Point p, int layer)
    + rotate(double r)
    + scale(double s)
    + position() : Point
    + layer() : int
    + angle() : double
    + angleOld() : double
    + scale() : double
    + scaleOld() : double
    + toString() : String
    + update() : void
  }
  Transform ..|> ITransform
  
  class Segmento {
    --
    + p1() : Point
    + p2() : Point
    + intersecao(Segmento that) : boolean
  }
  
  class Poligono {
    - tipoPol : int
    --
    + pontos() : Point[]
    + segmentos() : Segmento[]
    + contemOPonto(Point p) : boolean
    + colisaoCirculo(Circle c) : boolean
    + colisaoPoligono(Poligono p) : boolean
    + translation(dx: double dx, dy: double) : Poligono
    + translation(p: Point) : Figura
    + centroid() : Point
    + scale(s: double) : Figura
    + rotate(r: double) : Figura
    + toString() : String
  }
  Poligono --|> Figura
  
  class Circle {
    - radius : double
    --
    + center() : Point
    + radius() : double
    + translation(dx: double, dy: double) : Circle
    + translation(p: Point) : Figura
    + intersetaSegmento(s: Segmento) : boolean
    + colisaoCirculo(c: Circle) : boolean
    + colisaoPoligono(p: Poligono) : boolean
    + centroid() : Point
    + scale(r: double) : Figura
    + rotate(r: double) : Figura
    + collision(that: Figura) : boolean
    + toString() : String
  }
  Circle --|> Figura
  
  class Collider {
    - centroid : Point
    --
    + updateFig() : void
    + centroid() : Point
    + toString() : String
    + collidesWith(other: ICollider) : boolean
  }
  Collider ..|> ICollider
  
  class GameObject {
    - name : String
    --
    + posSpeed() : Point
    + layerSpeed() : int
    + rotationSpeed() : double
    + scaleSpeed() : double
    + move(Point p, int layer) : void
    + rotate(double r) : void
    + scale(double s) : void
    + generateNextFrame() : void
    + name() : String
    + transform() : Transform
    + collider() : Collider
    + colision(GameObject that) : boolean
  }
  GameObject ..|> IGameObject

  class GameEngine {
    - layers : HashMap<Integer, ArrayList<GameObject>>
    --
    + gameObjects : ArrayList<GameObject>
    + layers : HashMap<Integer, ArrayList<GameObject>>
    + add : void
    + destroy : void
    + generateNextFrame : void
    + simulateFrames : void
    + detectCollisions : ArrayList<String>
  }
  GameEngine ..|> IGameEngine
}
 '================== Game ==================
package "Game" {
  Class PlayerBehaviour {
      
  }
  PlayerBehaviour ..|> IBehaviour
  Class Enemy1Behaviour {
    
  }
  Enemy1Behaviour ..|> IBehaviour
  Class Enemy2Behaviour {
   
  }
  Enemy2Behaviour ..|> IBehaviour
  Class Enemy3Behaviour {
    
  }
  Enemy3Behaviour ..|> IBehaviour
  Class HPBehaviour {
    
  }
  HPBehaviour ..|> IBehaviour
  Class PointsBehaviour {
    
  }
  PointsBehaviour ..|> IBehaviour

  Class Entity {
    - health : int
    - attack : ArrayList<Integer>
    --
    + health() : int
    + damage() : ArrayList<Integer>
    + heal() : void
    + damage(Entity that) : void
  }
}

'================== Associations ==================
' Segmento "has" 2 Points (start and end)
Segmento "1" --> "2" Point : p1,p2

' Poligono "has" an array (n) of Points and an array (n) of Segmentos
Poligono "1" --> "*" Point : pontos
Poligono "1" --> "*" Segmento : segmentos

' Circle "has" exactly 1 center Point.
Circle "1" --> "1" Point : center

' Collider holds references to 1 Figura and 1 Transform.
Collider "1" --> "1" Figura : fig
Collider "1" --> "1" Transform : transform
Collider "1" --> "1" Point : centroid

' Transform has 1 point '
Transform "1" --> "1" Point : position

' GameObject has 1 Transform and 1 Collider.
GameObject "1" --> "1" ITransform : transform
GameObject "1" --> "1" ICollider : collider

' GameEngine has * GameObjects
GameEngine "1" --> "*" GameObject : gameObjects

' Some Behaviours have 1 Entity
PlayerBehaviour "1" --> "1" Entity : entity
Enemy1Behaviour "1" --> "1" Entity : entity
Enemy2Behaviour "1" --> "1" Entity : entity
Enemy3Behaviour "1" --> "1" Entity : entity


@enduml