@startuml
left to right direction
title Java Game

'================== Interfaces ==================
package "Interfaces" {
  interface IGameObject {
    + String name()
    + ITransform transform()
    + ICollider collider()
    + IShape shape()
    + IBehaviour behaviour()
    + void render()
  }
  interface ITransform {
    + move(Point p, int layer)
    + rotate(double r)
    + scale(double s)
    + Point position()
    + int layer()
    + double angle()
    + double scale()
    + void setDirection(int i)
    + int getDirection()
    + String toString()
  }
  interface ICollider {
    + Point centroid()
    + void setTransform(ITransform transform)
    + void onUpdate()
    + boolean isColliding(ICollider that)
    + igure getHitbox()
    + String toString()
  }
  interface IBehaviour {
    + void oninit()
    + void onEnable()
    + void onDisable()
    + void onDestroy()
    + void onUpdate(double dT)
    + void onCollision(ArrayList<IGameObject> gol)
    + void setGO(IGameObject GO)
  }
  interface IGameEngine {
    + HashMap<Integer, ArrayList<IGameObject>> layers()
    + ArrayList<IGameObject> enabled()
    + ArrayList<IGameObject> disabled()
    + void generateNextFrame()
    + void addEnabled(IGameObject go)
    + void addDisabled(IGameObject go)
    + void enable(IGameObject go)
    + void disable(IGameObject go)
    + boolean isEnabled(IGameObject go)
    + boolean isDisabled(IGameObject go)
    + void destroy(IGameObject go)
    + void run()
    + void checkCollisions()
  }
  interface IShape {
    + oid render(Graphics g, int x, int y)
    + void setColor(Color color)
  }
}

'================== Game Engine ==================
package "Engine" {
  abstract class Figura {
    - int tipoFig
    --
    + Point[] pontos()
    + Segmento[] segmentos()
    + bollean containsPoint(Point p)
    + void checkPol()
    + boolean collisionCircle(Circle that)
    + boolean collisionPolygon(Polygon that)
    + boolean collision(Figure that)
    + Point[] translatePoints(double dx, double dy)
    + Polygon translation(double dx, double dy)
    + Polygon translation(Point p)
    + Point centroid()
    + Figure scale(double s)
    + Figure rotate(double r)
    + String toString()
    + double minX()
    + double maxX()
    + double minY()
    + double maxY()
  }
  
  class Point {
    - double x
    - double y
    --
    + double x()
    + double y()
    + int X()
    + int Y()
    + boolean equals(Point that)
    + double distancia(Point that)
    + Point translacao(double dx, double dy)
    + Point sum(Point that)
    + boolean colinear(Point a, Point b, Point c)
    + Point flipSign() : Point
    + Point scale(double s)
    + Point rotate(double deg) 
    + Point vetor(Point that)
    + double vetorPI(Point v1, Point v2)
    + double vetorPE(Point v1, Point v2)
    + String toString()
  }
  
  class Transform {
    - int layer
    - double angle
    - double scale
    - int direction
    --
    + Point position()
    + int layer()
    + double angle()
    + double scale()
    + int getDirection()
    + String toString()
    + void update() 
    + void move(Point p, int layer)
    + void rotate(double r)
    + void scale(double s)
    + void setDirection(int i)

  }
  Transform ..|> ITransform
  
  class Segmento {
    --
    + Point p1()
    + Point p2()
    + boolean intersection(Segmento that) 
  }
  
  class Poligono {
    - int tipoPol
  }
  Poligono --|> Figura
  
  class Circle {
    - double radius
  }
  Circle --|> Figura
  
  class Collider {
    - double angleOld
    - double scaleOld
    --
    + void setTransform(ITransform transform)
    + void onUpdate()
    + Point centroid()
    + boolean isColliding(ICollider that)
    + Figure getHitbox()
    + String toString() 
  }
  Collider ..|> ICollider
  
  class Shape {
    void setColor(Color color)
    void render(Graphics g, int x, int y)
  }
  Shape ..|> IShape  

  class GameObject {
    - name : String
    --
    + void insertElements(ITransform transform, ICollider collider, IShape shape, IBehaviour behaviour)
    + String name()
    + ITransform transform()
    + ICollider collider()
    + IShape shape()
    + IBehaviour behaviour()
    + void render(Graphics g)
  }
  GameObject ..|> IGameObject

  class GameEngine {
    - GameEngine instance
    - HashMap<Integer, ArrayList<IGameObject>> layers
    - HashMap<IGameObject, ArrayList<IGameObject>> collisionMap
    - int TARGET_FPS
    - boolean isRunning
    - Canvas window
    --
    + int getScreenWidth()
    + int getScreenHeight()
    + GameEngine getInstance()
    + ArrayList<IGameObject> enabled()
    + ArrayList<IGameObject> disabled()
    + HashMap<Integer, ArrayList<IGameObject>> layers()
    + void addEnabled(IGameObject go)
    + void addDisabled(IGameObject go)
    + void enable(IGameObject go)
    + void disable(IGameObject go)
    + boolean isEnabled(IGameObject go)
    + boolean isDisabled(IGameObject go)
    + void destroy(IGameObject go)
    + void destroyAll()
    + void manageGO()
    + void run()
    + void render()
    + void setWindow()
    + void generateNextFrame()
    + void simulateFrames()
    + void checkCollisions()
  }
  GameEngine ..|> IGameEngine
}
 '================== Game ==================
package "Game" {
  Class ABehaviour {
    + void oninit()
    + void onEnable()
    + void onDisable()
    + void onDestroy()
    + void onCollision()
    + void onUpdate(double dT)
    + void setGO(IGameObject GO)
  }
  Class Physics {
    - int layerSpeed
    - double rotationSpeed
    - double scaleSpeed
    --
    + void update(double  dT)
    + Point Speed()
    + Point Accel()
    + int LayerSpeed()
    + double RotationSpeed()
    + double ScaleSpeed()
    + void setAccel(double x, double y)
    + void sumAccel(double x, double y)
    + void setSpeed(double x, double y)
    + void setLayerSpeed(int layerSpeed)
    + void snapToFloor(IGameObject GOm, IGameObject GOp)
    + void snapToCeling(IGameObject GOm, IGameObject GOp)
    + void snapToWallOnTheLeft(IGameObject GOm, IGameObject GOp)
    + void snapToWallOnTheRight(IGameObject GOm, IGameObject GOp)
  }
  Class AI {
    + void update()
  }
  Class PlayerBehaviour {
    - double deltaTime
    - long now
    - boolean isGrounded
    - long jumpStart
    - boolean stopedJumping
    - IGameObject attack1
    --
    + Physics physics()
    + Entity entity(
    + void setGrounded(boolean isGrounded)
  }
  PlayerBehaviour --|> ABehaviour

  Class EnemyBehaviour1 {
  }
  EnemyBehaviour1 --|> ABehaviour

  Class EnemyBehaviour2 {
  }
  EnemyBehaviour2 --|> ABehaviour

  Class EnemyBehaviour3 {
  }
  EnemyBehaviour3 --|> ABehaviour

  Class STBehaviour {
    - int roomKey
    - int posKey
  }
  STBehaviour --|> ABehaviour
  
  Class StaticBehaviour {
  }
  StaticBehaviour --|> ABehaviour

  Class BlockBehaviour {
    
  }
  BlockBehaviour --|> ABehaviour


  Class Entity {
    - int health
    - long attackStart
    - long damageTime
    --
    + int getHealth()
    + void damage(int damage)
    + void heal()
    + void createAttack(IGameObject attack1, long now)
    + void disableAttack(IGameObject attack1, long now)
  }

  Class BlockShape {
    - int width
    - int height
  }
  BlockShape ..|> IShape   

  Class HUDHealthBarShape {
    Color color
  }
  HUDHealthBarShape ..|> IShape  

  Class HUDPointsShape {
    Color color
  }
  HUDPointsShape ..|> IShape

  Class ObjectCreator {
    + IGameObject Player(double x, double y)
    + IGameObject Enemy1(double x, double y)
    + IGameObject loading_screen(double x, double y, int roomKey, int posKey)
    + IGameObject floor()
    + GameObject block(double x, double y, double width, double height)
    + IGameObject blockWall(double x, double y, double width, double height, String name)
    + IGameObject playerAttack1(int width, int height)
    + IGameObject healthHUD()
  }
}

'================== Associations ==================
' Segmento "has" 2 Points (start and end)
Segmento "1" --> "2" Point : p1,p2

' Poligono "has" an array (n) of Points and an array (n) of Segmentos
Poligono "1" --> "*" Point : pontos
Poligono "1" --> "*" Segmento : segmentos

' Circle "has" exactly 1 center Point.
Circle "1" --> "1" Point : center

' Collider holds references to 1 Figura and 1 Transform.
Collider "1" --> "1" Figura : fig
Collider "1" --> "1" Transform : transform
Collider "1" --> "1" Point : centroid

' Transform has 1 point '
Transform "1" --> "1" Point : position

' GameObject has 1 Transform and 1 Collider.
GameObject "1" --> "1" ITransform : transform
GameObject "1" --> "1" ICollider : collider
GameObject "1" --> "1" IBehaviour : behaviour
GameObject "1" --> "1" IShape : shape

' GameEngine has * GameObjects
GameEngine "1" --> "*" GameObject : enabledList
GameEngine "1" --> "*" GameObject : disabledList
GameEngine "1" --> "*" GameObject : toEnable
GameEngine "1" --> "*" GameObject : toDisable
GameEngine "1" --> "*" GameObject : toAddEnable
GameEngine "1" --> "*" GameObject : toAddDisable
GameEngine "1" --> "*" GameObject : toDestroy

' Behaviours
ABehaviour "1" --> "1" IGameObject : myGo

PlayerBehaviour "1" --> "1" Entity : entity
PlayerBehaviour "1" --> "1" GameObject : attack1
PlayerBehaviour "1" --> "1" Physics : physics

EnemyBehaviour1 "1" --> "1" Entity : entity
EnemyBehaviour1 "1" --> "1" Physics : physics 
EnemyBehaviour1 "1" --> "1" AI : AI 

EnemyBehaviour2 "1" --> "1" Entity : entity
EnemyBehaviour2 "1" --> "1" Physics : physics 
EnemyBehaviour2 "1" --> "1" AI : AI 

EnemyBehaviour3 "1" --> "1" Entity : entity
EnemyBehaviour3 "1" --> "1" Physics : physics 
EnemyBehaviour3 "1" --> "1" AI : AI 

BlockBehaviour "1" --> "1" IGameObject : topHitbox
BlockBehaviour "1" --> "1" IGameObject : leftHitbox
BlockBehaviour "1" --> "1" IGameObject : rightHitbox
BlockBehaviour "1" --> "1" IGameObject : bottomHitbox

' AI
AI "1" --> "1" IGameObject : vision

' Physics
Physics "1" --> "1" Point : speed
Physics "1" --> "1" Point : accel
Physics "1" --> "1" Point : gravity

' Entity
Entity "1" --> "1" IGameObject : go
Entity "1" --> "1" IGameEngine : engine

' HUD
HUDHealthBarShape "1" --> "1" IGameEngine : engine
HUDPointsShape "1" --> "1" IGameEngine : engine
@enduml