@startuml
left to right direction
title Java Game Engine

'================== Interfaces ==================
package "Interfaces" {
  interface IGameObject {
    + name() : String
    + transform() : Transform
    + collider() : Collider
  }
  interface ITransform {
    + move(p: Point, layer: int)
    + rotate(r: double)
    + scale(s: double)
    + position() : Point
    + layer() : int
    + angle() : double
    + scale() : double
  }
  interface ICollider {
    + centroid() : Point
  }
}

'================== Classes ==================
package "Classes" {
  abstract class Figura {
    - tipoFig : int
    --
    + centroid() : Point
    + scale(r: double) : Figura
    + rotate(r: double) : Figura
    + translation(dx: double, dy: double) : Figura
    + translation(p: Point) : Figura
    + toString() : String
    + collision(that: Figura) : boolean
  }
  
  class Point {
    - x : double
    - y : double
    --
    + x() : double
    + y() : double
    + X() : int
    + Y() : int
    + equals(that: Point) : boolean
    + distancia(that: Point) : double
    + translacao(dx: double, dy: double) : Point
    + sum(that: Point) : Point
    + colinear(a: Point, b: Point, c: Point) : boolean
    + flipSign() : Point
    + scale(s: double) : Point
    + rotate(deg: double) : Point
    + vetor(that: Point) : Point
    + vetorPI(v1: Point, v2: Point) : double
    + vetorPE(v1: Point, v2: Point) : double
    + toString() : String
  }
  
  class Transform {
    - layer : int
    - angle : double
    - angleOld : double
    - scale : double
    - scaleOld : double
    --
    + move(p: Point, layer: int)
    + rotate(r: double)
    + scale(s: double)
    + position() : Point
    + layer() : int
    + angle() : double
    + angleOld() : double
    + scale() : double
    + scaleOld() : double
    + toString() : String
    + update() : void
  }
  Transform ..|> ITransform
  
  class Segmento {
    --
    + p1() : Point
    + p2() : Point
    + intersecao(that: Segmento) : boolean
  }
  
  class Poligono {
    - tipoPol : int
    --
    + pontos() : Point[]
    + segmentos() : Segmento[]
    + contemOPonto(p: Point) : boolean
    + colisaoCirculo(c: Circle) : boolean
    + colisaoPoligono(p: Poligono) : boolean
    + translation(dx: double, dy: double) : Poligono
    + translation(p: Point) : Figura
    + centroid() : Point
    + scale(s: double) : Figura
    + rotate(r: double) : Figura
    + toString() : String
  }
  Poligono --|> Figura
  
  class Circle {
    - radius : double
    --
    + center() : Point
    + radius() : double
    + translation(dx: double, dy: double) : Circle
    + translation(p: Point) : Figura
    + intersetaSegmento(s: Segmento) : boolean
    + colisaoCirculo(c: Circle) : boolean
    + colisaoPoligono(p: Poligono) : boolean
    + centroid() : Point
    + scale(r: double) : Figura
    + rotate(r: double) : Figura
    + collision(that: Figura) : boolean
    + toString() : String
  }
  Circle --|> Figura
  
  class Collider {
    - centroid : Point
    --
    + updateFig() : void
    + centroid() : Point
    + toString() : String
    + collidesWith(other: ICollider) : boolean
  }
  Collider ..|> ICollider
  
  class GameObject {
    - name : String
    --
    + posSpeed : Point
    + layerSpeed : int
    + rotationSpeed : double
    + scaleSpeed : double
    + move(p: Point, layer: int) : void
    + rotate(r: double) : void
    + scale(s: double) : void
    + generateNextFrame() : void
    + name() : String
    + transform() : Transform
    + collider() : Collider
    + colision(that: GameObject) : boolean
  }
  GameObject ..|> IGameObject
}

'================== Associations ==================
' Segmento "has" 2 Points (start and end)
Segmento "1" --> "2" Point : p1,p2

' Poligono "has" an array (n) of Points and an array (n) of Segmentos
Poligono "1" --> "*" Point : pontos
Poligono "1" --> "*" Segmento : segmentos

' Circle "has" exactly 1 center Point.
Circle "1" --> "1" Point : center

' Collider holds references to 1 Figura and 1 Transform.
Collider "1" --> "1" Figura : fig
Collider "1" --> "1" Transform : transform
Collider "1" --> "1" Point : centroid

' Transform has 1 point '
Transform "1" --> "1" Point : position

' GameObject has 1 Transform and 1 Collider.
GameObject "1" --> "1" Transform : transform
GameObject "1" --> "1" Collider : collider

@enduml
